# Copie para .env e preencha (não commite .env).
# Vercel: Settings → Environment Variables (Production + Preview) → novo deploy.

VITE_SUPABASE_PROJECT_ID=seu-project-ref
VITE_SUPABASE_URL=https://seu-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-anon-publica

# Mapbox — busca de endereço em Meu Perfil (geocoding; token público com URL restrita)
VITE_MAPBOX_ACCESS_TOKEN=

# Alternativa aceita no build (vite.config): SUPABASE_URL + SUPABASE_ANON_KEY

# Evolution API (WhatsApp) — opcional no .env: comunicador oficial usa URL/chave salvos no painel Admin.
# Útil para o comunicador pessoal (2º slot) ou desenvolvimento local.
# VITE_EVOLUTION_API_URL=https://seu-servidor.evolution.com
# VITE_EVOLUTION_API_KEY=sua-api-key

# Webhook n8n — eventos Comunicar (motorista executivo). O padrão já está no código; use só para staging/outro fluxo.
# VITE_N8N_COMUNICAR_WEBHOOK_URL=https://n8n.e-transporte.pro/webhook/...
